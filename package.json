{
  "name": "effect-dynamodb-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "check": "pnpm -r check",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "docs:dev": "pnpm --filter @effect-dynamodb/docs dev",
    "docs:build": "pnpm --filter @effect-dynamodb/docs build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "tsx": "^4.21.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract",
      "sharp"
    ]
  }
}
